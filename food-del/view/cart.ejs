<!DOCTYPE html>
<html>
<head>
  <title>Cart</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<h1 class="text-3xl text-center mt-5 font-bold">
Your Cart
</h1>

<% if(cart.length > 0) { %>
<h2 class="text-2xl text-center mt-5">Total: Rs <%= total %></h2>
<% } %>

<div class="grid grid-cols-3 gap-6 p-10">

  <% if(cart.length === 0) { %>

    <h2>No items in cart</h2>

  <% } %>


  <% cart.forEach(function(item, index){ %>

    <div onclick="window.location.href='/details?foodName=<%= encodeURIComponent(item.foodName) %>&price=<%= item.price %>&image=<%= encodeURIComponent(item.image) %>&description=<%= encodeURIComponent(item.description) %>'" class="bg-white p-4 shadow rounded">
        

      <img class="w-full h-40 object-cover mb-2" src="<%= item.image %>">

      <h2 class="text-xl font-bold">
        <%= item.foodName %>
      </h2>

      <p>
        Price : Rs <%= item.price %>
      </p>

     
      
     <form action="/removeItem/<%= item._id %>" method="POST">
        <button type="submit" onclick="event.stopPropagation()" class="bg-red-500 text-white px-3 py-1 mt-2">
          Remove
        </button>
      </form>
    </div>

  <% }) %>


</div>
<button onclick="window.location.href='/payment'" class="bg-green-500 text-white px-4 py-2 mt-5 center mx-auto block animate-pulse">
  Make Payment
</button>
<link rel="stylesheet" href="/output.css">

</body>
</html>